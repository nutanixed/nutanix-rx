# --- NUTANIX CLUSTER CONNECTIVITY ---
PE_IP=10.0.0.10
PC_IP=10.0.0.20

# --- SYSTEM CREDENTIALS ---
ADMIN_PASSWORD=change-me
SSH_USER=nutanix
SSH_PASS=change-me
PE_USER=api-user
PE_PASS=change-me
PC_USER=api-user
PC_PASS=change-me
FSVM_USER=nutanix
FSVM_PASS=change-me
CIMC_USER=admin
CIMC_PASS=change-me
LDAP_ADMIN_DN=cn=admin,dc=example,dc=local
LDAP_ADMIN_PASS=change-me
AUTH_USERNAME=local-admin
AUTH_PASSWORD=change-me

# --- INFRASTRUCTURE TOPOLOGY ---
CIMC_HOSTS=host-a-cimc.example.local,host-b-cimc.example.local,host-c-cimc.example.local
AHV_IPS=10.0.0.101,10.0.0.102,10.0.0.103
CVM_IPS=10.0.0.111,10.0.0.112,10.0.0.113
PCVM_IPS=10.0.0.31,10.0.0.32,10.0.0.33
FSVM_IPS=172.30.32.101,172.30.32.102,172.30.32.103

# --- VM MANAGEMENT GROUPS ---
# Management VM selectors (comma-separated):
# - values ending with "_" are treated as prefixes (e.g., "system_" matches all system_* VMs)
# - other values are treated as exact VM names
MGMT_VM_NAMES=system_,auto_DND_calm_policy_engine_1f4dfdb8
FSVM_VM_NAMES=NTNX-fsnkp-1,NTNX-fsnkp-2,NTNX-fsnkp-3
FSVM_NAME_PATTERN=NTNX-fsnkp
NKP_MGMT_PATTERN=nkp-clus20
NKP_WORKER_PATTERN=nkp-clus20-md
NKP_API_IP=10.0.0.100
NKP_K8S_PORT=6443
NKP_RECOVERY_NAMESPACES=kommander,kommander-default-workspace,ntnx-system,nai-system,kube-system

# NKP Automation Timing
NKP_STARTUP_STABILIZE_DELAY=60
NKP_MAX_RETRIES=10
NKP_RETRY_DELAY=30
NKP_DRAIN_TIMEOUT=60s
NKP_POD_RECOVERY_SETTLE_TIME=5

# --- INFRASTRUCTURE TIMING ---
DEFAULT_MAX_RETRIES=30
DEFAULT_RETRY_DELAY=30
MGMT_MAX_RETRIES=20
MGMT_RETRY_DELAY=30
SHUTDOWN_ALL_EXCLUDE_PATTERN=^nkp-clus20

# Automated Orchestration Wait Times (Startup)
WAIT_AFTER_HOSTS=600
WAIT_AFTER_PE=600
WAIT_AFTER_PCVM=600
WAIT_AFTER_PC_CLUSTER=120
WAIT_AFTER_FS_POWER=120
WAIT_AFTER_FS_CLUSTER=120
WAIT_AFTER_MGMT=120
WAIT_BEFORE_NKP=60

# Automated Orchestration Wait Times (Shutdown)
WAIT_AFTER_NKP=300
WAIT_AFTER_FSVM=180
WAIT_AFTER_USER_VMS=120
WAIT_AFTER_PC_CLUSTER_STOP=120
WAIT_AFTER_PCVM_STOP=120
WAIT_AFTER_PE_CLUSTER_STOP=120
WAIT_AFTER_CVM=120
WAIT_AFTER_AHV=180

# NDK Webhook Management
ENABLE_NDK=false

# --- AUTHENTICATION & SECURITY ---
LDAP_SERVER=ldap://ldap.example.local:389
LDAP_USER_SEARCH_BASE=ou=People,dc=example,dc=local
LDAP_USER_ATTRIBUTE=uid
SECRET_KEY=replace-with-long-random-secret
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_PATH=/
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/THIS/WEBHOOK
LOGOUT_REDIRECT_URL=https://auth.example.com/logout
CONSOLE_BASE_URL=https://console.example.com
